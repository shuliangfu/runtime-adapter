{
  "name": "@dreamer/runtime-adapter",
  "version": "1.2.1",
  "description": "Runtime adaptation layer providing a unified API abstraction compatible with Deno, Bun, and Node.js runtimes (file, env, path, process, network, cron).",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/shuliangfu/dreamer-jsr.git"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./fs": "./src/fs.ts",
    "./path": "./src/path-mod.ts",
    "./process": "./src/process-mod.ts",
    "./net": "./src/net.ts"
  },
  "scripts": {
    "test": "bun test tests/",
    "test:deno": "deno test -A tests/",
    "test:node": "tsx --test --test-force-exit tests/*.test.ts",
    "test:all": "deno test -A tests/ && bun test tests/ && tsx --test --test-force-exit tests/*.test.ts"
  },
  "dependencies": {
    "@dreamer/i18n": "npm:@jsr/dreamer__i18n@^1.1.0",
    "node-cron": "npm:node-cron@3.0.3",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@dreamer/test": "npm:@jsr/dreamer__test@^1.2.1",
    "tsx": "^4.23.1"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=22"
  },
  "keywords": [
    "runtime",
    "adapter",
    "deno",
    "bun",
    "node",
    "nodejs",
    "unified-api",
    "filesystem",
    "env",
    "path",
    "process",
    "cron",
    "dreamer"
  ]
}
